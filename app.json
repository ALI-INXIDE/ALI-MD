{
  "name": "ALI-MD",
  "version": "10.0.0",
  "description": "ALI-MD is a powerful Multi Device WhatsApp Bot designed to enhance automation, moderation, and user experience on WhatsApp.",
  "logo": "https://files.catbox.moe/m8t72a.jpg",
  "keywords": [
    "ali-md",
    "whatsapp-bot",
    "multi-device",
    "baileys",
    "automation",
    "bot"
  ],

  "success_url": "/",

  "stack": "heroku-24",

  "env": {
    "SESSION_ID": {
      "description": "Your WhatsApp SESSION_ID. Generate it from the pairing website.",
      "required": true,
      "value": ""
    },

    "PREFIX": {
      "description": "Bot command prefix.",
      "required": false,
      "value": "."
    },

    "OWNER_NAME": {
      "description": "Bot owner name.",
      "required": false,
      "value": "б¬ҠНңНЎрқҗҖЙӯД«Д« рқҗҲрқҗҚрқ…Ұрқҗ—Д«Д«рқҗғрқҗ„ к«ӮвғҹрҹҮәрҹҮё"
    },

    "OWNER_NUMBER": {
      "description": "Owner WhatsApp number without + sign.",
      "required": false,
      "value": "923147725823"
    },

    "BOT_NAME": {
      "description": "Your bot display name.",
      "required": false,
      "value": "р“Ҷ©бҖҜбӘірқҗҖЙӯД«Д«-рқҗҢрқҗғбҖҫбӘір“ҶӘ"
    },

    "BOT_PIC": {
      "description": "Bot menu profile image URL.",
      "required": false,
      "value": "https://files.catbox.moe/m8t72a.jpg"
    },

    "MODE": {
      "description": "Use public - groups - private mode.",
      "required": true,
      "value": "public"
    },

    "TIME_ZONE": {
      "description": "Timezone e.g Asia/Karachi.",
      "required": false,
      "value": "Asia/Karachi"
    },

    "PRESENCE": {
      "description": "Set Presence status in online/typing/recording.",
      "required": false,
      "value": "offline"
    },

    "ANTIDELETE": {
      "description": "Enable anti-delete mode.",
      "required": false,
      "value": "pm"
    },

    "ANTICALL": {
      "description": "Auto reject calls true/false.",
      "required": false,
      "value": "false"
    },

    "ANTICALL_MSG": {
      "description": "Message sent when rejecting calls.",
      "required": false,
      "value": "*_рҹ“һ Auto Call Reject Mode Active. рҹ“ө No Calls Allowed!_*"
    },

    "AUTO_LIKE_STATUS": {
      "description": "Auto-like WhatsApp statuses.",
      "required": false,
      "value": "true"
    },

    "AUTO_READ_STATUS": {
      "description": "Auto-view WhatsApp statuses.",
      "required": false,
      "value": "true"
    },

    "STATUS_LIKE_EMOJIS": {
      "description": "Status reaction emojis separated by commas.",
      "required": false,
      "value": "рҹ’ӣ,вқӨпёҸ,рҹ’ң,рҹӨҚ,рҹ’ҷ"
    },

    "AUTO_REPLY_STATUS": {
      "description": "Auto reply to statuses.",
      "required": false,
      "value": "false"
    },

    "STATUS_REPLY_TEXT": {
      "description": "Reply text for viewed statuses.",
      "required": false,
      "value": "*status viewed successfully вң…*"
    },

    "AUTO_READ_MESSAGES": {
      "description": "Auto read messages groups/dm.",
      "required": false,
      "value": "off"
    },

    "AUTO_BIO": {
      "description": "Enable auto bio update.",
      "required": false,
      "value": "false"
    },

    "AUTO_BLOCK": {
      "description": "Numbers to auto block.",
      "required": false,
      "value": ""
    },

    "PACK_NAME": {
      "description": "Sticker pack name.",
      "required": false,
      "value": "РјОұвҲӮС” РІСғ Оұв„“О№-РјвҲӮ,рҹ•·пёҸ"
    },

    "SUDO_NUMBERS": {
      "description": "Sudo numbers separated by commas.",
      "required": false,
      "value": ""
    },

    "DATABASE_URL": {
      "description": "Optional PostgreSQL connection URL. Leave blank to use SQLite.",
      "required": false,
      "value": ""
    }
  },

  "addons": [
    {
      "plan": "heroku-postgresql:essential-0",
      "as": "DATABASE"
    }
  ],

  "buildpacks": [
    {
      "url": "heroku/nodejs"
    },
    {
      "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest"
    }
  ],

  "environments": {
    "test": {
      "addons": [],
      "env": {
        "DATABASE_URL": ""
      }
    }
  }
}
