# WhatsApp Session ID (Required)
SESSION_ID=

# Owner WhatsApp Number (without +)
OWNER_NUMBER=

# ==========================================
# Database (Optional)
# Leave blank to use SQLite.
#
# Free PostgreSQL providers:
# https://neon.tech
# https://supabase.com
# https://railway.com
# https://render.com
# ==========================================
DATABASE_URL=

# ==========================================
# Optional Settings
# ==========================================
MODE=public
PREFIX=.
TIME_ZONE=Asia/Karachi
